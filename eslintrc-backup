{
  "parser": "babel-eslint",
  "env": {
    "es6": true,
    "browser": true,
    "node": true,
  },

  "settings": {
    "ecmascript": 6,
    "jsx": true,
  },

  "extends": "airbnb",

  "rules": {
    "no-console": 1,
    "no-unused-vars": 1,
    "comma-dangle": 1,
    "lines-between-class-members": ["error", "always",
      { "exceptAfterSingleLine": true }],
    "arrow-parens": [2, "as-needed"],
    "react/jsx-filename-extension": [1, { "extensions": [".js", ".jsx"] }],
  },

  "plugins": ["html", "markdown", "react","json"],

}
